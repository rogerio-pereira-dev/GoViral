        'email' => 'mass@example.com',
        'aspiring_niche' => 'Lifestyle',
        'payment_status' => 'pending',
        'processing_status' => 'waiting_payment_confirmation',
        'forbidden_attr' => 'must_not_appear',
    ];

// Even better
// Although the closing brackets could have 4 spaces, because of assignment it's easier to visualize the chain if 
// closing bracket is aligned to opening bracket
$payload = [
                'email' => 'mass@example.com',
                'aspiring_niche' => 'Lifestyle',
                'payment_status' => 'pending',
                'processing_status' => 'waiting_payment_confirmation',
                'forbidden_attr' => 'must_not_appear',
            ];
```

